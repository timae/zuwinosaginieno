# Copy to `.env` (which is git-ignored) and fill in. run_scrape.sh sources it.

# --- Postgres (optional) ---------------------------------------------------- #
# If set, each run loads the scraped JSONL into Postgres (idempotent UPSERT).
# DATABASE_URL=postgresql://user:pass@localhost:5432/wines

# --- Telegram notifications (optional) -------------------------------------- #
# Get a bot token from @BotFather (/newbot). Then message your bot once and read
# your chat id from https://api.telegram.org/bot<TOKEN>/getUpdates (chat.id).
# TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token...
# TELEGRAM_CHAT_ID=123456789

# --- Scrape scope (optional; these are the defaults) ------------------------ #
# VIVINO_COUNTRIES=ch,fr,it,es,us,de,pt,at
# VIVINO_TYPES=1,2,3,4
# VIVINO_MAX_PAGES=25
# VIVINO_MIN_DELAY=3
# VIVINO_MAX_DELAY=8
